# ============================================================
# ScorpStudy — Environment Variables Template
# ============================================================
# Copy this file to .env (Bun loads it automatically) OR paste
# each value into the Replit Secrets tab.
#
# The app accepts any of the listed names for each variable —
# use whichever format your provider gives you.
#
# PORTABILITY NOTE
# ----------------
# Replit Secrets do NOT transfer when you ZIP and re-upload a
# project. After importing into a new Replit, you have two options:
#
#   Option A (recommended): Copy this file to ".env", fill in
#   your values, and save it. Bun loads .env automatically on
#   startup — no Replit Secrets tab needed.
#
#   Option B: Re-enter each value in the Replit Secrets tab.
#
# The app will print a clear warning at startup listing any
# missing variables so you know exactly what to add.
# ============================================================

# ------------------------------------------------------------
# SUPABASE — required for auth, database, and storage
# ------------------------------------------------------------
# Project URL (find in: Supabase Dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon / public key  (accepted names: SUPABASE_ANON_KEY or SUPABASE_PUBLISHABLE_KEY)
SUPABASE_ANON_KEY=eyJ...

# Service role key — KEEP SECRET, never expose to the browser
# (find in: Supabase Dashboard → Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------------------------------------------------------------
# AI PROVIDERS — at least one group is required
# ------------------------------------------------------------

# Groq  (free tier available — console.groq.com)
# Supports up to 5 keys for automatic rotation / rate-limit fallback
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...
GROQ_API_KEY_4=gsk_...
GROQ_API_KEY_5=gsk_...

# Google Gemini  (free tier available — aistudio.google.com)
# Supports up to 5 keys for automatic rotation / rate-limit fallback
GEMINI_API_KEY_1=AIza...
GEMINI_API_KEY_2=AIza...
GEMINI_API_KEY_3=AIza...
GEMINI_API_KEY_4=AIza...
GEMINI_API_KEY_5=AIza...

# OpenAI  (platform.openai.com)
OPENAI_API_KEY=sk-...

# Hugging Face  (huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=hf_...
